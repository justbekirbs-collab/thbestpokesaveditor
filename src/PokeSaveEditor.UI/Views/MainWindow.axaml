<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PokeSaveEditor.UI.ViewModels"
        xmlns:views="using:PokeSaveEditor.UI.Views"
        x:Class="PokeSaveEditor.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1150" Height="780"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FormatString" Value="0"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Save File..."
                          Command="{Binding OpenFileCommand}"
                          HotKey="Ctrl+O"
                          InputGesture="Ctrl+O" />
                <MenuItem Header="_Save Save File..."
                          Command="{Binding SaveFileCommand}"
                          HotKey="Ctrl+S"
                          InputGesture="Ctrl+S"
                          IsEnabled="{Binding IsFileLoaded}" />
                <Separator />
                <MenuItem Header="E_xit"
                          Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" />
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="12,6">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Opacity="0.8" />
        </Border>

        <!-- Main Grid Layout -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Save File Info Card -->
            <Border Grid.Row="0" Classes="card"
                    IsVisible="{Binding IsFileLoaded}">
                <StackPanel Spacing="4">
                    <TextBlock Classes="header" Text="Save File Information" />
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <StackPanel>
                            <TextBlock Text="Trainer" FontSize="11" Opacity="0.6" />
                            <TextBlock Text="{Binding Metadata.TrainerName}" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Trainer ID" FontSize="11" Opacity="0.6" />
                            <TextBlock Text="{Binding Metadata.TrainerId}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Generation" FontSize="11" Opacity="0.6" />
                            <TextBlock Text="{Binding Metadata.Generation}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Play Time" FontSize="11" Opacity="0.6" />
                            <TextBlock Text="{Binding Metadata.PlayTime}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Empty State -->
            <StackPanel Grid.Row="1"
                        IsVisible="{Binding !IsFileLoaded}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <TextBlock Text="🎮"
                           FontSize="64"
                           HorizontalAlignment="Center" />
                <TextBlock Text="No save file loaded"
                           FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Opacity="0.6" />
                <Button Content="Open Save File"
                        Command="{Binding OpenFileCommand}"
                        HorizontalAlignment="Center"
                        Classes="accent"
                        Padding="24,10" />
            </StackPanel>

            <!-- Working Mode Grid -->
            <Grid Grid.Row="1" ColumnDefinitions="3*,2*" IsVisible="{Binding IsFileLoaded}">
                
                <!-- Left Side: List and Trainer Card Tabs -->
                <TabControl Grid.Column="0">
                    <TabItem Header="Party Pokémon">
                        <DockPanel Margin="0,10,0,0">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                <Button Content="Add Pokémon" Command="{Binding AddToPartyCommand}" Classes="accent" HotKey="Ctrl+A"/>
                                <Button Content="Delete Selected" Command="{Binding DeleteSelectedCommand}" IsEnabled="{Binding SelectedPokemon, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            </StackPanel>
                            <Border Classes="card">
                                <views:PokemonListView DataContext="{Binding PartyList}" />
                            </Border>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="PC Boxes">
                        <DockPanel Margin="0,10,0,0">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                <Button Content="Add Pokémon" Command="{Binding AddToPCCommand}" Classes="accent"/>
                                <Button Content="Delete Selected" Command="{Binding DeleteSelectedCommand}" IsEnabled="{Binding SelectedPokemon, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            </StackPanel>
                            <Border Classes="card">
                                <views:PokemonListView DataContext="{Binding BoxList}" />
                            </Border>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Trainer Details">
                        <Border Classes="card" Margin="0,10,0,0" VerticalAlignment="Stretch">
                            <StackPanel Spacing="16" MaxWidth="500" HorizontalAlignment="Left">
                                <TextBlock Text="Edit Trainer Profile" Classes="header" FontSize="16" />
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Trainer Name" FontSize="12" Opacity="0.7"/>
                                    <TextBox Text="{Binding Metadata.TrainerName, Mode=TwoWay}" MaxLength="7"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Trainer ID" FontSize="12" Opacity="0.7"/>
                                    <NumericUpDown Value="{Binding TrainerId, Mode=TwoWay}" Minimum="0" Maximum="65535"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Gym Badges" FontSize="12" Opacity="0.7"/>
                                    <WrapPanel>
                                        <CheckBox Content="Badge 1" IsChecked="{Binding Badge1}" Margin="0,0,12,0"/>
                                        <CheckBox Content="Badge 2" IsChecked="{Binding Badge2}" Margin="0,0,12,0"/>
                                        <CheckBox Content="Badge 3" IsChecked="{Binding Badge3}" Margin="0,0,12,0"/>
                                        <CheckBox Content="Badge 4" IsChecked="{Binding Badge4}" Margin="0,0,12,0"/>
                                        <CheckBox Content="Badge 5" IsChecked="{Binding Badge5}" Margin="0,0,12,0"/>
                                        <CheckBox Content="Badge 6" IsChecked="{Binding Badge6}" Margin="0,0,12,0"/>
                                        <CheckBox Content="Badge 7" IsChecked="{Binding Badge7}" Margin="0,0,12,0"/>
                                        <CheckBox Content="Badge 8" IsChecked="{Binding Badge8}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </TabItem>
                </TabControl>

                <!-- Right Side: Selected Pokémon Editor -->
                <ScrollViewer Grid.Column="1" Margin="16,0,0,0">
                    <Grid>
                        <!-- Placeholder state (No selection) -->
                        <Border Classes="card" IsVisible="{Binding SelectedPokemon, Converter={x:Static ObjectConverters.IsNull}}" VerticalAlignment="Stretch" MinHeight="400">
                            <StackPanel Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="Select a Pokémon to Edit" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Click any Pokémon in your Party or PC list to view and customize its properties." FontSize="12" Opacity="0.6" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Editing Form -->
                        <Border Classes="card" IsVisible="{Binding SelectedPokemon, Converter={x:Static ObjectConverters.IsNotNull}}" VerticalAlignment="Stretch">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Pokémon Editor" Classes="header" FontSize="16"/>
                                <Separator/>

                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,6,8">
                                        <TextBlock Text="Nickname" FontSize="11" Opacity="0.7"/>
                                        <TextBox Text="{Binding SelectedNickname, Mode=TwoWay}" MaxLength="10"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="6,0,0,8">
                                        <TextBlock Text="Level" FontSize="11" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding SelectedLevel, Mode=TwoWay}" Minimum="1" Maximum="100"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                                        <TextBlock Text="Species" FontSize="11" Opacity="0.7"/>
                                        <ComboBox ItemsSource="{Binding SpeciesList}" SelectedItem="{Binding SelectedSpecies, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="6,0,0,0">
                                        <TextBlock Text="Nature" FontSize="11" Opacity="0.7"/>
                                        <ComboBox ItemsSource="{Binding NaturesList}" SelectedItem="{Binding SelectedNature, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="*,*">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                        <CheckBox Content="Shiny ✨" IsChecked="{Binding SelectedPokemonIsShiny, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Ability Slot" FontSize="11" Opacity="0.7"/>
                                        <ComboBox ItemsSource="{Binding AbilitiesList}" SelectedItem="{Binding SelectedAbility, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Moves" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,0"/>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,6,8">
                                        <TextBlock Text="Move 1 ID" FontSize="11" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding SelectedMove1Id, Mode=TwoWay}" Minimum="0" Maximum="1000"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="6,0,0,8">
                                        <TextBlock Text="Move 2 ID" FontSize="11" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding SelectedMove2Id, Mode=TwoWay}" Minimum="0" Maximum="1000"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                                        <TextBlock Text="Move 3 ID" FontSize="11" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding SelectedMove3Id, Mode=TwoWay}" Minimum="0" Maximum="1000"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="6,0,0,0">
                                        <TextBlock Text="Move 4 ID" FontSize="11" Opacity="0.7"/>
                                        <NumericUpDown Value="{Binding SelectedMove4Id, Mode=TwoWay}" Minimum="0" Maximum="1000"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                                    <!-- IVs -->
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                                        <TextBlock Text="IVs" FontWeight="SemiBold" FontSize="12"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="HP" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding SelectedIvHp, Mode=TwoWay}" Minimum="0" Maximum="31" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Atk" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding SelectedIvAtk, Mode=TwoWay}" Minimum="0" Maximum="31" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Def" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding SelectedIvDef, Mode=TwoWay}" Minimum="0" Maximum="31" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Spe" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding SelectedIvSpe, Mode=TwoWay}" Minimum="0" Maximum="31" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="SpA" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding SelectedIvSpa, Mode=TwoWay}" Minimum="0" Maximum="31" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="SpD" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding SelectedIvSpd, Mode=TwoWay}" Minimum="0" Maximum="31" Height="26" FontSize="11"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- EVs -->
                                    <StackPanel Grid.Column="1" Spacing="4" Margin="6,0,0,0">
                                        <TextBlock Text="EVs" FontWeight="SemiBold" FontSize="12"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="HP" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding SelectedEvHp, Mode=TwoWay}" Minimum="0" Maximum="255" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Atk" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding SelectedEvAtk, Mode=TwoWay}" Minimum="0" Maximum="255" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Def" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding SelectedEvDef, Mode=TwoWay}" Minimum="0" Maximum="255" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Spe" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding SelectedEvSpe, Mode=TwoWay}" Minimum="0" Maximum="255" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="SpA" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding SelectedEvSpa, Mode=TwoWay}" Minimum="0" Maximum="255" Height="26" FontSize="11"/>
                                            
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="SpD" FontSize="11" Width="30" VerticalAlignment="Center"/>
                                            <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding SelectedEvSpd, Mode=TwoWay}" Minimum="0" Maximum="255" Height="26" FontSize="11"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
